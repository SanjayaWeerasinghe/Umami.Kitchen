---
/**
 * BowlStage — the fixed, full-viewport video background.
 *
 * Design:
 *   - Poster JPG is painted from the very first frame, so there is no
 *     black flash while the video downloads on cellular.
 *   - The <video> is scrubbed by scroll on ALL viewports (including mobile).
 *   - Only genuinely hostile environments fall back permanently to the
 *     poster: reduced motion, reduced data / saveData, 2g/slow-2g, or a
 *     video error. Small viewport is NOT a reason to fall back — modern
 *     mobile browsers scrub muted playsinline videos fine once unlocked.
 *   - iOS gesture unlock: if autoplay-muted is rejected on load, we hook
 *     the first touchstart/scroll to re-attempt play()/pause() so
 *     currentTime seeks start rendering frames.
 */
---

<div id="bowl-stage" aria-hidden="true">
  <video
    id="bowl-video"
    src="/bowl.mp4"
    preload="auto"
    muted
    playsinline
    disablepictureinpicture
    disableremoteplayback
    poster="/bowl-poster.jpg"
  ></video>
  <img id="bowl-poster" src="/bowl-poster.jpg" alt="" />
  <div id="bowl-scrim"></div>
</div>

<script>
  /* eslint-disable @typescript-eslint/no-explicit-any */
  interface BowlAPI {
    ready: Promise<number>;
    setProgress: (p: number) => void;
    isFallback: () => boolean;
  }

  declare global {
    interface Window {
      __bowlAPI?: BowlAPI;
    }
  }

  const stage = document.getElementById('bowl-stage') as HTMLDivElement | null;
  const video = document.getElementById('bowl-video') as HTMLVideoElement | null;

  if (stage && video) {
    // Poster is visible by default (see CSS: #bowl-poster { display: block }
    // when stage[data-fallback='true'], but we also want it visible during
    // initial video load). We handle this by showing the poster over the
    // video until the video's first frame is drawn.
    stage.dataset.loading = 'true';

    // -----------------------------------------------------------------
    // Decide whether to permanently fall back to the poster (no scrub).
    // Small viewport is NOT a trigger — we let mobile try to scrub.
    // -----------------------------------------------------------------
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const reducedData = window.matchMedia('(prefers-reduced-data: reduce)').matches;

    const nav = navigator as Navigator & {
      connection?: { effectiveType?: string; saveData?: boolean };
    };
    const conn = nav.connection;
    const slowNet =
      !!conn && (conn.saveData === true || ['slow-2g', '2g'].includes(conn.effectiveType ?? ''));

    const useFallback = reducedMotion || reducedData || slowNet;

    if (useFallback) {
      stage.dataset.fallback = 'true';
      stage.dataset.loading = 'false';
      window.__bowlAPI = {
        ready: Promise.resolve(0),
        setProgress: () => {},
        isFallback: () => true,
      };
    } else {
      // ---------------------------------------------------------------
      // Scrub path — works on desktop AND mobile with the right unlocks.
      // ---------------------------------------------------------------
      let resolveReady: (d: number) => void = () => {};
      const ready = new Promise<number>((res) => {
        resolveReady = res;
      });
      let isReady = false;
      let hasUnlocked = false;

      // iOS Safari refuses currentTime seeks on paused videos that have
      // never played. play()/pause() unlocks scrubbing. On some devices,
      // autoplay-muted works immediately; on others we need a user gesture.
      function tryUnlock() {
        if (hasUnlocked) return;
        const p = video!.play();
        if (p && typeof (p as any).then === 'function') {
          (p as Promise<void>)
            .then(() => {
              hasUnlocked = true;
              video!.pause();
              // Once we've decoded a frame, hide the poster overlay
              stage!.dataset.loading = 'false';
            })
            .catch(() => {
              // Autoplay blocked — wait for a real user gesture, then retry.
              // Any of these will do; whichever fires first wins.
              const gestureUnlock = () => {
                video!.play().then(() => {
                  hasUnlocked = true;
                  video!.pause();
                  stage!.dataset.loading = 'false';
                }).catch(() => {
                  // Still blocked. Show poster and give up on scrubbing.
                  stage!.dataset.fallback = 'true';
                  stage!.dataset.loading = 'false';
                });
                window.removeEventListener('touchstart', gestureUnlock);
                window.removeEventListener('pointerdown', gestureUnlock);
                window.removeEventListener('scroll', gestureUnlock);
              };
              window.addEventListener('touchstart', gestureUnlock, { once: true, passive: true });
              window.addEventListener('pointerdown', gestureUnlock, { once: true, passive: true });
              window.addEventListener('scroll', gestureUnlock, { once: true, passive: true });
            });
        } else {
          hasUnlocked = true;
          stage!.dataset.loading = 'false';
        }
      }

      function markReady() {
        if (isReady) return;
        isReady = true;
        tryUnlock();
        resolveReady(video!.duration || 0);
      }

      if (video.readyState >= 2 && video.duration) {
        markReady();
      } else {
        video.addEventListener('loadeddata', markReady, { once: true });
        video.addEventListener('canplay', markReady, { once: true });
        video.addEventListener('canplaythrough', markReady, { once: true });
      }
      video.addEventListener('error', () => {
        stage!.dataset.fallback = 'true';
        stage!.dataset.loading = 'false';
        resolveReady(0);
      });
      // Safety timeout — never leave the layout hanging
      setTimeout(() => {
        if (!isReady) markReady();
      }, 6000);

      window.__bowlAPI = {
        ready,
        setProgress(p: number) {
          if (!isReady) return;
          const d = video!.duration;
          if (!d || isNaN(d)) return;
          // If scrubbing was never unlocked (e.g. autoplay blocked and no
          // gesture yet), the seek may silently no-op. That's OK — the
          // gesture handler above will unlock on the first scroll.
          video!.currentTime = Math.max(0, Math.min(d - 0.05, p * d));
        },
        isFallback: () => stage!.dataset.fallback === 'true',
      };
    }
  }
</script>
